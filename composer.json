{
    "name": "robothead/woocommerce-conditional-shipping-fields",
    "description": "Hide WooCommerce checkout address fields based on the selected shipping method, configurable per method inside shipping zone settings.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Robothead",
            "email": "robert@robothead.eu",
            "homepage": "https://robothead.eu"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Robothead\\WcConditionalFields\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
